{
  "info": {
    "name": "ShopBuilder Defense",
    "description": "Ready-to-run auth and ShopBuilder business endpoints for the oral defense.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "storeId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"owner{{$timestamp}}@example.com\",\n  \"password\": \"StrongPass!2026\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "auth", "register"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json();",
              "pm.collectionVariables.set('accessToken', data.access_token);",
              "pm.collectionVariables.set('refreshToken', data.refresh_token);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"owner@example.com\",\n  \"password\": \"StrongPass!2026\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json();",
              "pm.collectionVariables.set('accessToken', data.access_token);",
              "pm.collectionVariables.set('refreshToken', data.refresh_token);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Auth - Refresh",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/refresh",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "auth", "refresh"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json();",
              "pm.collectionVariables.set('accessToken', data.access_token);",
              "pm.collectionVariables.set('refreshToken', data.refresh_token);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Stores - Onboard Merchant",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Nomad Home {{$timestamp}}\",\n  \"subdomain\": \"nomad-home-{{$timestamp}}\",\n  \"custom_domain\": \"shop-{{$timestamp}}.nomad-home.kz\",\n  \"currency_code\": \"KZT\",\n  \"timezone\": \"Asia/Almaty\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/stores/onboard",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "stores", "onboard"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json();",
              "pm.collectionVariables.set('storeId', data.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Stores - List Mine",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/stores",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "stores"]
        }
      }
    },
    {
      "name": "Products - Variant Matrix",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Minimal Hoodie {{$timestamp}}\",\n  \"handle\": \"minimal-hoodie-{{$timestamp}}\",\n  \"vendor\": \"Nomad Essentials\",\n  \"base_sku\": \"NH-HOODIE-{{$timestamp}}\",\n  \"price_amount\": 18990,\n  \"attributes\": [\n    {\"name\": \"Size\", \"values\": [\"S\", \"M\"]},\n    {\"name\": \"Color\", \"values\": [\"Black\", \"White\"]},\n    {\"name\": \"Material\", \"values\": [\"Cotton\"]}\n  ],\n  \"locations\": [\n    {\"name\": \"Almaty Warehouse\", \"city\": \"Almaty\", \"default_quantity_per_variant\": 10}\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/stores/{{storeId}}/products/variant-matrix",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "stores", "{{storeId}}", "products", "variant-matrix"]
        }
      }
    },
    {
      "name": "Products - List With Cursor",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/stores/{{storeId}}/products?limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "stores", "{{storeId}}", "products"],
          "query": [
            {
              "key": "limit",
              "value": "10"
            }
          ]
        }
      }
    },
    {
      "name": "Webhooks - Inbound Event",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"provider_name\": \"kaspi_pay\",\n  \"provider_event_id\": \"evt_{{$timestamp}}\",\n  \"event_type\": \"payment.succeeded\",\n  \"occurred_at\": \"2026-04-24T10:33:00Z\",\n  \"signature\": \"t=1713954780,v1=deadbeef\",\n  \"payload\": {\n    \"order_id\": \"ord_001\",\n    \"status\": \"captured\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/stores/{{storeId}}/webhooks/inbound",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "stores", "{{storeId}}", "webhooks", "inbound"]
        }
      }
    },
    {
      "name": "Webhooks - List Events",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/stores/{{storeId}}/webhooks/events",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "stores", "{{storeId}}", "webhooks", "events"]
        }
      }
    },
    {
      "name": "Auth - Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/logout",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "auth", "logout"]
        }
      }
    }
  ]
}
