APP_NAME=ShopBuilder API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
PLATFORM_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/shopbuilder_platform
TENANT_DATABASE_URLS={"merchant_alpha":"postgresql+psycopg://postgres:postgres@postgres:5432/merchant_alpha","merchant_beta":"postgresql+psycopg://postgres:postgres@postgres:5432/merchant_beta"}
REDIS_URL=redis://redis:6379/0
