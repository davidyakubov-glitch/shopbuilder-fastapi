APP_NAME=ShopBuilder API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
PLATFORM_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/shopbuilder_platform
TENANT_DATABASE_URLS={"merchant_alpha":"postgresql+psycopg://postgres:postgres@postgres:5432/merchant_alpha","merchant_beta":"postgresql+psycopg://postgres:postgres@postgres:5432/merchant_beta"}
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=change-me-super-secret-access-key-123
JWT_REFRESH_SECRET_KEY=change-me-super-secret-refresh-key-456
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
WEBHOOK_SIGNING_SECRET=change-me-super-secret-webhook-key-789
THEME_SANDBOX_MODE=strict
DEFAULT_CURRENCY=KZT
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
APP_PUBLIC_URL=http://localhost:8000
EMAIL_PROVIDER=resend
EMAIL_FROM=ShopBuilder <onboarding@resend.dev>
RESEND_API_KEY=
EMAIL_DELIVERY_MODE=queue
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
EMAIL_TOKEN_TTL_MINUTES=60
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
